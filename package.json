{
  "name": "@agarwal29796/manim-js",
  "version": "0.1.0",
  "description": "Manim.js — a Manim-inspired, framework-agnostic animation engine for the web. Author scenes in code; render anywhere via a tiny Renderer interface.",
  "license": "Apache-2.0",
  "author": "Archit Agarwal <archit@mirelz.com>",
  "type": "module",
  "keywords": [
    "animation",
    "manim",
    "motion-graphics",
    "canvas",
    "svg",
    "math",
    "education",
    "explainer",
    "timeline",
    "whiteboard"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agarwal29796/manim-js.git"
  },
  "homepage": "https://github.com/agarwal29796/manim-js#readme",
  "bugs": {
    "url": "https://github.com/agarwal29796/manim-js/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./canvas": {
      "import": {
        "types": "./dist/canvas.d.ts",
        "default": "./dist/canvas.js"
      },
      "require": {
        "types": "./dist/canvas.d.cts",
        "default": "./dist/canvas.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:exports": "publint --strict && attw --pack . --profile node16",
    "studio:bundle": "esbuild studio/main.ts --bundle --format=iife --outfile=studio/bundle.js",
    "studio": "npm run studio:bundle && python3 -m http.server -d studio 8123",
    "gallery:bundle": "esbuild gallery/main.ts --bundle --format=iife --outfile=gallery/bundle.js",
    "gallery": "npm run gallery:bundle && python3 -m http.server -d gallery 8124",
    "build:site": "npm run gallery:bundle && npm run studio:bundle && rm -rf site && mkdir -p site/studio && cp gallery/index.html gallery/bundle.js site/ && cp studio/index.html studio/bundle.js site/studio/",
    "site": "npm run build:site && python3 -m http.server -d site 8125",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "esbuild": "^0.24.0",
    "publint": "^0.2.12",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
